generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WatchStatus {
  PLANNED
  WATCHING
  COMPLETED
}

enum ContentType {
  MOVIE
  TV_SHOW
  BOOK
  GAME
}

model WatchlistItem {
  id           String      @id @default(uuid())
  imdbId       String?
  externalId   String
  source       String      @default("OMDB")
  title        String
  author       String?     @db.VarChar(255)
  year         String
  type         String
  contentType  ContentType @default(MOVIE)
  collection   String?
  poster       String?
  status       WatchStatus
  rating       Int?
  notes        String?
  favorite     Boolean     @default(false)
  deletedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([source, externalId])
  @@index([status])
  @@index([title])
  @@index([type])
  @@index([contentType])
  @@index([deletedAt])
}

model Collection {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}


